{
  "name": "kuwenta",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "test": "dotenv -e .env.test -- vitest",
    "test:unit": "dotenv -e .env.test -- vitest run",
    "test:run": "pnpm run test:unit && pnpm run verify:computations",
    "test:ui": "dotenv -e .env.test -- vitest --ui",
    "verify:computations": "dotenv -e .env.test -- tsx scripts/verify-computations.ts",
    "db:test:migrate": "dotenv -e .env.test -- prisma migrate deploy",
    "db:migrate:deploy": "dotenv -e .env -- prisma migrate deploy",
    "db:test:reset": "tsx scripts/ensure-test-db.ts",
    "sync:changelog": "tsx scripts/sync-changelog.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@prisma/client": "^5",
    "@react-pdf/renderer": "^4.5.1",
    "@stellar/stellar-sdk": "^12",
    "bcrypt": "^5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "decimal.js": "^10",
    "exceljs": "^4.4.0",
    "jose": "^5",
    "jszip": "^3.10.1",
    "lucide-react": "^1.21.0",
    "next": "15.5.19",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-qr-code": "^2.2.0",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "xlsx": "^0.18.5",
    "zod": "^3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/bcrypt": "^5",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10",
    "dotenv": "^16",
    "dotenv-cli": "^8",
    "eslint": "^9",
    "eslint-config-next": "15.5.19",
    "eslint-plugin-react-hooks": "^7.1.1",
    "postcss": "^8",
    "prisma": "^5",
    "tailwindcss": "^4.3.1",
    "ts-node": "^10",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "bcrypt",
      "prisma"
    ]
  }
}
